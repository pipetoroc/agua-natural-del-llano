---
import Input from './Input.astro'
import ContactCard from './ContactCard.astro'
import Logo from './icons/Logo.astro'
---

<section class="pt-40 pb-14 text-center bg-cream">
  <h1
    class="text-secondary font-title text-3xl/relaxed tracking-wide font-bold">
    Contacto
  </h1>
  <p class="font-text text-2xl font-medium tracking-wide text-secondary/75">
    Ponte en contacto para pedidos, dudas o lo que necesites.
  </p>
  <div class="flex flex-wrap pt-16 gap-7">
    <form
      action=""
      class="flex flex-wrap flex-1 pl-20 gap-4">
      <h2
        class="mb-8 w-full text-secondary font-text text-xl/relaxed tracking-wide font-semibold">
        Envíanos un mensaje
      </h2>
      <div class="flex flex-col flex-1 items-start gap-0.5">
        <Input
          class="flex flex-col"
          description="Nombre y apellido"
          title="Nombre y apellido"
        />
      </div>

      <div class="flex flex-col flex-1 items-start gap-0.5">
        <Input
          description="Teléfono"
          title="Tu nombre"
        />
      </div>

      <div class="flex flex-col w-full items-start gap-0.5">
        <Input
          description="Dirección de correo electrónico"
          title="Correo electrónico"
        />
      </div>

      <label for="">Mensaje</label>
      <textarea
        class="w-full bg-white py-3 px-4 rounded-lg border border-secondary/20"
        name=""
        id=""
        cols="30"
        rows="10"
        placeholder="Déjanos tu mensaje"
      ></textarea>
      <button
        class="bg-secondary text-white py-3 px-6 rounded-3xl font-medium mt-2"
        type="submit"
        >Enviar mensaje</button
      >
    </form>
    <div class="flex-1 pr-20">
      <h2
        class="mb-8 w-full text-secondary font-text text-xl/relaxed tracking-wide font-semibold">
        ¿Qué funciona mejor para ti?
      </h2>
      <div class="flex flex-col py-8 px-6 bg-[#084991] gap-9 mt-3 rounded-2xl">
        <ContactCard
          title="Whatsapp"
          description="+57 320 962 9449"
        />
        <ContactCard
          title="Teléfono"
          description="+57 320 962 9449"
        />
        <ContactCard
          title="Email"
          description="+57 320 962 9449"
        />

        <ContactCard
          title="Ubicación"
          description="Calle 35 N.° 51-29, La Azotea, Villavicencio, Colombia"
        />
      </div>
    </div>
  </div>

  <div class="mt-20 w-full flex flex-col items-center justify-center gap-4">
    <Logo
      height="100"
      strokeColor="#084991"
      fillColor="#084991"
    />
    <h3
      class="text-title text-xl/snug font-normal tracking-wide text-secondary">
      Naturalmente Llanera
    </h3>
  </div>
</section>
